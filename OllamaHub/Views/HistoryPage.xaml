<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="OllamaHub.Views.HistoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:models="using:OllamaHub.Models"
      Background="#0F0F13">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- Header -->
    <Border Grid.Row="0" Background="#13131A"
            BorderBrush="#1E1E2E" BorderThickness="0,0,0,1" Padding="28,20">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Spacing="4">
          <StackPanel Orientation="Horizontal" Spacing="12">
            <Border Background="#22FFFFFF" CornerRadius="8" Padding="8">
              <FontIcon Glyph="&#xE81C;" FontSize="18" Foreground="#8A63FF"/>
            </Border>
            <TextBlock Text="Chat History" FontSize="26" FontWeight="Bold"
                       Foreground="#EEEEFF" VerticalAlignment="Center"/>
          </StackPanel>
          <TextBlock Text="Browse and manage your past conversations"
                     FontSize="13" Foreground="#555577" Margin="0,4,0,0"/>
        </StackPanel>
        <Border Grid.Column="1" Background="#1A1A24" BorderBrush="#2A2A3A"
                BorderThickness="1" CornerRadius="10">
          <TextBox Width="240" PlaceholderText="&#xE71E;  Search history..."
                   Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                   BorderThickness="0" Background="Transparent"
                   Foreground="#DDDDEF" Padding="12,10"/>
        </Border>
      </Grid>
    </Border>

    <!-- Session cards -->
    <ScrollViewer Grid.Row="1" Padding="28,20">
      <ItemsControl ItemsSource="{x:Bind ViewModel.FilteredSessions, Mode=OneWay}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="models:ChatSession">
            <Border Background="#1A1A24" BorderBrush="#2A2A3A" BorderThickness="1"
                    CornerRadius="14" Padding="20,16" Margin="0,0,0,10">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Color accent bar -->
                <Border Grid.Column="0" Width="4" CornerRadius="2" Margin="0,0,16,0">
                  <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                      <GradientStop Color="#8A63FF" Offset="0"/>
                      <GradientStop Color="#4F9EFF" Offset="1"/>
                    </LinearGradientBrush>
                  </Border.Background>
                </Border>

                <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center">
                  <TextBlock Text="{x:Bind Title}" FontSize="15" FontWeight="SemiBold"
                             Foreground="#EEEEFF" TextTrimming="CharacterEllipsis"/>
                  <StackPanel Orientation="Horizontal" Spacing="12">
                    <Border Background="#22FFFFFF" CornerRadius="5" Padding="6,2">
                      <TextBlock Text="{x:Bind ModelName}" FontSize="11" Foreground="#8A63FF"/>
                    </Border>
                    <TextBlock Text="{x:Bind CreatedAt, Converter={StaticResource DateToTextConverter}}"
                               FontSize="11" Foreground="#555577" VerticalAlignment="Center"/>
                    <TextBlock Text="{x:Bind Messages.Count, Converter={StaticResource MessageCountConverter}}"
                               FontSize="11" Foreground="#555577" VerticalAlignment="Center"/>
                  </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8"
                            VerticalAlignment="Center">
                  <Button Click="DeleteSession_Click" Tag="{x:Bind}"
                          Background="#1E1E2E" BorderBrush="#2A2A3A"
                          CornerRadius="8" Width="36" Height="36" Padding="0"
                          ToolTipService.ToolTip="Delete">
                    <FontIcon Glyph="&#xE74D;" FontSize="14" Foreground="#FF6B6B"/>
                  </Button>
                </StackPanel>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </Grid>
</Page>
