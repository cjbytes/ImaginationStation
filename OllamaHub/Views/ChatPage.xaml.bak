<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OllamaHub.Views.ChatPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:OllamaHub.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- LEFT SIDEBAR -->
        <Grid Grid.Column="0"
              Background="{ThemeResource LayerFillColorDefaultBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Model selector -->
            <StackPanel Grid.Row="0" Margin="12,16,12,8" Spacing="6">
                <TextBlock Text="MODEL" FontSize="11" FontWeight="SemiBold"
                           CharacterSpacing="100"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <ComboBox x:Name="ModelComboBox"
                          ItemsSource="{x:Bind ViewModel.AvailableModels}"
                          SelectedIndex="0"
                          HorizontalAlignment="Stretch"
                          PlaceholderText="Select a model...">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="models:OllamaModelInfo">
                            <TextBlock Text="{x:Bind Name}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>

            <!-- New Chat button -->
            <Button Grid.Row="1"
                    Click="NewChat_Click"
                    HorizontalAlignment="Stretch"
                    Margin="12,4,12,8"
                    Style="{ThemeResource AccentButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE710;" FontSize="14" />
                    <TextBlock Text="New Chat" />
                </StackPanel>
            </Button>

            <!-- Sessions label -->
            <TextBlock Grid.Row="2"
                       Text="RECENT CHATS" FontSize="11" FontWeight="SemiBold"
                       CharacterSpacing="100"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="16,4,12,8" />

            <!-- Session list -->
            <ListView Grid.Row="3"
                      x:Name="SessionList"
                      ItemsSource="{x:Bind ViewModel.ChatSessions}"
                      SelectionChanged="SessionList_SelectionChanged"
                      Margin="8,0,8,8">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:ChatSession">
                        <StackPanel Padding="4,6" Spacing="2">
                            <TextBlock Text="{x:Bind Title}"
                                       FontSize="13" FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{x:Bind ModelName}"
                                       FontSize="11"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="CornerRadius" Value="6" />
                        <Setter Property="Margin" Value="0,2" />
                    </Style>
                </ListView.ItemContainerStyle>
            </ListView>
        </Grid>

        <!-- RIGHT: CHAT AREA -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Messages area -->
            <ScrollViewer Grid.Row="0"
                          x:Name="MessagesScroll"
                          VerticalScrollBarVisibility="Auto"
                          Padding="24,16,24,8">
                <StackPanel x:Name="MessagesPanel" Spacing="16">

                    <!-- Empty state -->
                    <StackPanel x:Name="EmptyState"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="12"
                                Margin="0,120,0,0">
                        <FontIcon Glyph="&#xE99A;" FontSize="48"
                                  Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                  HorizontalAlignment="Center" />
                        <TextBlock Text="OllamaHub"
                                   FontSize="28" FontWeight="Bold"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="Select a model and start chatting"
                                   FontSize="14"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>

                    <ItemsControl x:Name="MessagesList"
                                  ItemsSource="{x:Bind ViewModel.Messages, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:ChatMessage">
                                <Grid Margin="0,4">

                                    <!-- User bubble (right) -->
                                    <Border HorizontalAlignment="Right"
                                            MaxWidth="600"
                                            Background="{ThemeResource AccentFillColorDefaultBrush}"
                                            CornerRadius="18,18,4,18"
                                            Padding="16,10"
                                            Margin="80,0,0,0"
                                            Visibility="{x:Bind IsUser, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="{x:Bind Content}"
                                                   Foreground="White"
                                                   TextWrapping="Wrap"
                                                   FontSize="14"
                                                   IsTextSelectionEnabled="True" />
                                    </Border>

                                    <!-- Assistant bubble (left) -->
                                    <Border HorizontalAlignment="Left"
                                            MaxWidth="680"
                                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                            CornerRadius="18,18,18,4"
                                            Padding="16,12"
                                            Margin="0,0,80,0"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            Visibility="{x:Bind IsAssistant, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <StackPanel Spacing="8">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE99A;" FontSize="11"
                                                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                                <TextBlock Text="{x:Bind ModelName}"
                                                           FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                            </StackPanel>
                                            <TextBlock Text="{x:Bind Content, Mode=OneWay}"
                                                       TextWrapping="Wrap"
                                                       FontSize="14"
                                                       IsTextSelectionEnabled="True" />
                                            <ProgressRing
                                                IsActive="{x:Bind IsStreaming, Mode=OneWay}"
                                                Width="20" Height="20"
                                                Visibility="{x:Bind IsStreaming, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </ScrollViewer>

            <!-- Input area -->
            <Border Grid.Row="1"
                    Padding="16,12,16,20"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="0,1,0,0"
                    Background="{ThemeResource LayerFillColorDefaultBrush}">
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <TextBox x:Name="InputBox"
                                 Text="{x:Bind ViewModel.InputText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="Message OllamaHub..."
                                 AcceptsReturn="False"
                                 MaxHeight="120"
                                 TextWrapping="Wrap"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Padding="14,12"
                                 FontSize="14"
                                 KeyDown="InputBox_KeyDown"
                                 VerticalAlignment="Center" />
                    </Border>

                    <!-- Send / Stop button -->
                    <Button Grid.Column="1"
                            x:Name="SendButton"
                            Click="SendButton_Click"
                            Width="48" Height="48"
                            CornerRadius="12"
                            Style="{ThemeResource AccentButtonStyle}"
                            ToolTipService.ToolTip="Send (Enter)">
                        <FontIcon x:Name="SendIcon" Glyph="&#xE724;" FontSize="18" />
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>