<Page
    x:Class="OllamaHub.Views.CoPilotPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <Grid Background="{StaticResource Surface0Brush}" Padding="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="👨‍💻 CoPilot" Style="{StaticResource HeaderText}"/>
            <TextBlock Text="AI-powered code assistant for development tasks" 
                       Style="{StaticResource BodyText}"
                       Margin="0,8,0,0"/>
        </StackPanel>
        
        <!-- Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Input Panel -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,12,0">
                <StackPanel Spacing="16">
                    <TextBlock Text="Code Input" Style="{StaticResource TitleText}"/>
                    
                    <ComboBox x:Name="LanguageCombo" 
                              Header="Language"
                              PlaceholderText="Select programming language"
                              Width="200"
                              HorizontalAlignment="Left">
                        <x:String>C#</x:String>
                        <x:String>Python</x:String>
                        <x:String>JavaScript</x:String>
                        <x:String>TypeScript</x:String>
                        <x:String>Java</x:String>
                        <x:String>C++</x:String>
                        <x:String>Go</x:String>
                        <x:String>Rust</x:String>
                    </ComboBox>
                    
                    <TextBox x:Name="CodeInput"
                             Header="Your Code or Question"
                             PlaceholderText="Paste code or describe what you need..."
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             Height="400"
                             FontFamily="Consolas"
                             FontSize="13"/>
                    
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button Content="💡 Explain Code" 
                                Style="{StaticResource ModernButtonStyle}"
                                Click="ExplainCode_Click"/>
                        <Button Content="🐛 Find Bugs" 
                                Style="{StaticResource ModernButtonStyle}"
                                Click="FindBugs_Click"/>
                        <Button Content="✨ Optimize" 
                                Style="{StaticResource ModernButtonStyle}"
                                Click="Optimize_Click"/>
                        <Button Content="📝 Add Comments" 
                                Style="{StaticResource ModernButtonStyle}"
                                Click="AddComments_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            
            <!-- Output Panel -->
            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="12,0,0,0">
                <StackPanel Spacing="16">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="AI Response" Style="{StaticResource TitleText}" VerticalAlignment="Center"/>
                        <Button Content="📋 Copy" 
                                Style="{StaticResource ModernButtonStyle}"
                                Padding="8,4"
                                FontSize="12"
                                Click="CopyOutput_Click"/>
                    </StackPanel>
                    
                    <ScrollViewer Height="500" VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="OutputText"
                                   Text="AI response will appear here..."
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontFamily="Consolas"
                                   FontSize="13"
                                   LineHeight="20"/>
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </Grid>
        
        <!-- Quick Actions -->
        <Border Grid.Row="2" 
                Background="{StaticResource Surface2Brush}"
                CornerRadius="8"
                Padding="16"
                Margin="0,24,0,0">
            <StackPanel Spacing="8">
                <TextBlock Text="Quick Actions" 
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Generate Unit Tests" Style="{StaticResource ModernButtonStyle}" Padding="12,6" FontSize="12"/>
                    <Button Content="Convert to TypeScript" Style="{StaticResource ModernButtonStyle}" Padding="12,6" FontSize="12"/>
                    <Button Content="Add Error Handling" Style="{StaticResource ModernButtonStyle}" Padding="12,6" FontSize="12"/>
                    <Button Content="Refactor for SOLID" Style="{StaticResource ModernButtonStyle}" Padding="12,6" FontSize="12"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>
