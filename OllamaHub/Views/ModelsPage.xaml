<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OllamaHub.Views.ModelsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:OllamaHub.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <ScrollViewer>
        <StackPanel Margin="24" Spacing="24">

            <!-- Header -->
            <TextBlock Text="Model Manager" FontSize="28" FontWeight="Bold" />

            <!-- Pull a model -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="20">
                <StackPanel Spacing="12">
                    <TextBlock Text="Download Model" FontSize="16" FontWeight="SemiBold" />
                    <TextBlock Text="Enter an Ollama model name (e.g. llama3.2:3b, mistral:7b)"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="13" />

                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{x:Bind ViewModel.PullModelName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="e.g. llama3.2:3b"
                                 IsEnabled="{x:Bind ViewModel.IsPulling, Converter={StaticResource BoolInverseConverter}, Mode=OneWay}" />
                        <Button Grid.Column="1"
                                Command="{x:Bind ViewModel.PullModelCommand}"
                                Style="{ThemeResource AccentButtonStyle}"
                                IsEnabled="{x:Bind ViewModel.IsPulling, Converter={StaticResource BoolInverseConverter}, Mode=OneWay}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE896;" FontSize="14" />
                                <TextBlock Text="Pull" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="2"
                                Command="{x:Bind ViewModel.CancelPullCommand}"
                                Visibility="{x:Bind ViewModel.IsPulling, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                            Cancel
                        </Button>
                    </Grid>

                    <!-- Progress -->
                    <ProgressBar Value="{x:Bind ViewModel.PullProgress, Mode=OneWay}"
                                 Maximum="100"
                                 Visibility="{x:Bind ViewModel.IsPulling, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" />
                    <TextBlock Text="{x:Bind ViewModel.PullStatus, Mode=OneWay}"
                               FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>

            <!-- Popular models quick list -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="20">
                <StackPanel Spacing="12">
                    <TextBlock Text="Quick Download" FontSize="16" FontWeight="SemiBold" />
                    <ItemsWrapGrid Orientation="Horizontal" />
                    <ItemsControl ItemsSource="{x:Bind ViewModel.PopularModels}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="6" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <Button Content="{x:Bind}"
                                        Margin="4"
                                        FontSize="12"
                                        Command="{Binding ElementName=ModelsRoot, Path=DataContext.QuickPullCommand}"
                                        CommandParameter="{x:Bind}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Local models list -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="20">
                <StackPanel Spacing="12">
                    <Grid>
                        <TextBlock Text="Installed Models" FontSize="16" FontWeight="SemiBold" />
                        <Button HorizontalAlignment="Right"
                                Command="{x:Bind ViewModel.RefreshModelsCommand}"
                                Style="{ThemeResource SubtleButtonStyle}">
                            <FontIcon Glyph="&#xE72C;" FontSize="14" />
                        </Button>
                    </Grid>

                    <ProgressRing IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                                  Visibility="{x:Bind ViewModel.IsBusy, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}"
                                  Width="32" Height="32" />

                    <ItemsControl ItemsSource="{x:Bind ViewModel.LocalModels, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:OllamaModelInfo">
                                <Grid Padding="0,10" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" FontSize="14" />
                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                            <TextBlock Text="{x:Bind Details.ParameterSize}"
                                                       FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            <TextBlock Text="{x:Bind Details.QuantizationLevel}"
                                                       FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            <TextBlock Text="{x:Bind DisplaySize}"
                                                       FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                    </StackPanel>

                                    <TextBlock Grid.Column="1"
                                               Text="{x:Bind Details.Family}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,16,0"
                                               FontSize="12"
                                               Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />

                                    <Button Grid.Column="2"
                                            ToolTipService.ToolTip="Delete model"
                                            Background="Transparent"
                                            Margin="0,0,4,0">
                                        <FontIcon Glyph="&#xE74D;" FontSize="14" Foreground="#FF3B30" />
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Visibility="{x:Bind ViewModel.LocalModels.Count, Converter={StaticResource ZeroToVisibilityConverter}, Mode=OneWay}"
                               Text="No models installed. Pull one above or run 'ollama pull &lt;model&gt;' in terminal."
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               FontSize="13" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
