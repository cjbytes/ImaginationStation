<Page
    x:Class="OllamaHub.Views.PersonasPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <Grid Background="{StaticResource Surface0Brush}" Padding="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <StackPanel Orientation="Horizontal" Spacing="16">
                <TextBlock Text="🎭 Personas" Style="{StaticResource HeaderText}" VerticalAlignment="Center"/>
                <Button Content="➕ Create New" 
                        Style="{StaticResource AccentButtonStyle}"
                        Click="CreatePersona_Click"/>
            </StackPanel>
            <TextBlock Text="Custom AI personalities with tailored system prompts and settings" 
                       Style="{StaticResource BodyText}"
                       Margin="0,8,0,0"/>
        </StackPanel>
        
        <!-- Personas Grid -->
        <GridView Grid.Row="1" 
                  x:Name="PersonasGrid"
                  SelectionMode="Single"
                  ItemClick="PersonaCard_Click"
                  IsItemClickEnabled="True">
            <GridView.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource CardStyle}"
                            Width="280"
                            Height="200"
                            Margin="8">
                        <Grid>
                            <StackPanel Spacing="12">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <TextBlock Text="{Binding Icon}" 
                                               FontSize="32"/>
                                    <TextBlock Text="{Binding Name}" 
                                               Style="{StaticResource TitleText}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                
                                <TextBlock Text="{Binding Description}"
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="12"
                                           MaxLines="3"
                                           TextTrimming="CharacterEllipsis"/>
                                
                                <StackPanel Spacing="4">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="🌡️ Temperature:" 
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextTertiaryBrush}"/>
                                        <TextBlock Text="{Binding Temperature}" 
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="📝 Max Tokens:" 
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextTertiaryBrush}"/>
                                        <TextBlock Text="{Binding MaxTokens}" 
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                            
                            <Button Content="✏️" 
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Style="{StaticResource ModernButtonStyle}"
                                    Padding="8"
                                    FontSize="12"
                                    Click="EditPersona_Click"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>
    </Grid>
</Page>
