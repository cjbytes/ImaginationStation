<Page
    x:Class="OllamaHub.Views.BatchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <Grid Background="{StaticResource Surface0Brush}" Padding="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="⚡ Batch Process" Style="{StaticResource HeaderText}"/>
            <TextBlock Text="Run the same prompt across multiple models and compare outputs" 
                       Style="{StaticResource BodyText}"
                       Margin="0,8,0,0"/>
        </StackPanel>
        
        <!-- Input Panel -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,16">
            <StackPanel Spacing="16">
                <TextBox x:Name="BatchPrompt"
                         Header="Prompt to test across all models"
                         PlaceholderText="Enter your prompt here..."
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         Height="120"/>
                
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Button Content="🚀 Run on All Models" 
                            Style="{StaticResource AccentButtonStyle}"
                            Click="RunBatch_Click"/>
                    <Button Content="📊 Compare Results" 
                            Style="{StaticResource ModernButtonStyle}"
                            Click="CompareResults_Click"/>
                    <Button Content="📁 Export Report" 
                            Style="{StaticResource ModernButtonStyle}"
                            Click="ExportReport_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
        
        <!-- Results Grid -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsRepeater x:Name="ResultsRepeater">
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                            <StackPanel Spacing="12">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <TextBlock Text="{Binding ModelName}" 
                                               Style="{StaticResource TitleText}"/>
                                    <Border Background="{StaticResource AccentBrush}"
                                            CornerRadius="4"
                                            Padding="8,4">
                                        <TextBlock Text="{Binding Status}" 
                                                   FontSize="11"
                                                   Foreground="White"/>
                                    </Border>
                                </StackPanel>
                                
                                <TextBlock Text="{Binding Response}"
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="13"
                                           LineHeight="20"/>
                                
                                <StackPanel Orientation="Horizontal" Spacing="16">
                                    <TextBlock>
                                        <Run Text="⏱️ " Foreground="{StaticResource TextTertiaryBrush}"/>
                                        <Run Text="{Binding ResponseTime}" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </TextBlock>
                                    <TextBlock>
                                        <Run Text="📊 " Foreground="{StaticResource TextTertiaryBrush}"/>
                                        <Run Text="{Binding TokenCount}" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </TextBlock>
                                    <TextBlock>
                                        <Run Text="🎯 " Foreground="{StaticResource TextTertiaryBrush}"/>
                                        <Run Text="{Binding QualityScore}" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </ScrollViewer>
    </Grid>
</Page>
