<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="OllamaHub.Views.TerminalPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#0A0A0E">
  <Grid Padding="20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Header bar -->
    <Border Grid.Row="0" Background="#13131A" BorderBrush="#1E1E2E"
            BorderThickness="1" CornerRadius="12,12,0,0" Padding="16,12">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <!-- Window dots -->
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
          <Ellipse Width="12" Height="12" Fill="#FF5F57"/>
          <Ellipse Width="12" Height="12" Fill="#FEBC2E"/>
          <Ellipse Width="12" Height="12" Fill="#28C840"/>
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10"
                    HorizontalAlignment="Center">
          <FontIcon Glyph="&#xE756;" FontSize="14" Foreground="#4CAF50"/>
          <TextBlock Text="Terminal" FontSize="14" FontWeight="SemiBold" Foreground="#CCCCDD"/>
          <TextBlock Text="â€”" Foreground="#333355"/>
          <TextBlock Text="{x:Bind ViewModel.WorkingDir, Mode=OneWay}"
                     FontSize="12" Foreground="#555577"
                     FontFamily="Cascadia Code, Consolas, monospace"
                     TextTrimming="CharacterEllipsis" MaxWidth="400"/>
        </StackPanel>
        <Button Grid.Column="2" Command="{x:Bind ViewModel.ClearOutputCommand}"
                Background="Transparent" BorderThickness="0" CornerRadius="6"
                Padding="8,4" ToolTipService.ToolTip="Clear terminal">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <FontIcon Glyph="&#xE74D;" FontSize="12" Foreground="#555577"/>
            <TextBlock Text="Clear" FontSize="12" Foreground="#555577"/>
          </StackPanel>
        </Button>
      </Grid>
    </Border>

    <!-- Output -->
    <Border Grid.Row="1" Background="#080810" BorderBrush="#1E1E2E"
            BorderThickness="1,0,1,0">
      <ScrollViewer x:Name="OutputScroll" VerticalScrollBarVisibility="Auto"
                    Padding="20,16">
        <TextBlock x:Name="OutputBlock"
                   Text="{x:Bind ViewModel.OutputText, Mode=OneWay}"
                   FontFamily="Cascadia Code, Consolas, monospace"
                   FontSize="13" Foreground="#D4D4D4"
                   TextWrapping="Wrap" IsTextSelectionEnabled="True"
                   LineHeight="20"/>
      </ScrollViewer>
    </Border>

    <!-- Input row -->
    <Border Grid.Row="2" Background="#13131A" BorderBrush="#1E1E2E"
            BorderThickness="1" CornerRadius="0,0,12,12" Padding="16,12">
      <Grid ColumnSpacing="12">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0" Text="$" FontSize="16" FontWeight="Bold"
                   Foreground="#4CAF50"
                   FontFamily="Cascadia Code, Consolas, monospace"
                   VerticalAlignment="Center"/>
        <TextBox Grid.Column="1" x:Name="CommandInput"
                 Text="{x:Bind ViewModel.InputCommand, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 PlaceholderText="Enter command... (â†‘â†“ for history)"
                 FontFamily="Cascadia Code, Consolas, monospace"
                 FontSize="13" Background="Transparent" Foreground="#E0E0E0"
                 BorderThickness="0" Padding="0,8"
                 KeyDown="CommandInput_KeyDown" VerticalAlignment="Center"/>
        <Button Grid.Column="2"
                Command="{x:Bind ViewModel.RunCommandCommand}"
                IsEnabled="{x:Bind ViewModel.IsRunning, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                Width="44" Height="38" CornerRadius="8" BorderThickness="0"
                ToolTipService.ToolTip="Run (Enter)">
          <Button.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
              <GradientStop Color="#28C840" Offset="0"/>
              <GradientStop Color="#2DD4BF" Offset="1"/>
            </LinearGradientBrush>
          </Button.Background>
          <FontIcon Glyph="&#xE768;" FontSize="14" Foreground="White"/>
        </Button>
      </Grid>
    </Border>
  </Grid>
</Page>
