п»ї<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:OllamaHub.Converters">

  <!-- ГўвЂќв‚¬ГўвЂќв‚¬ Converters ГўвЂќв‚¬ГўвЂќв‚¬ -->
  <converters:BoolToVisibilityConverter        x:Key="BoolToVisibilityConverter"/>
  <converters:BoolToInverseVisibilityConverter x:Key="BoolToInverseVisibilityConverter"/>
  <converters:BoolInverseConverter             x:Key="BoolInverseConverter"/>
  <converters:InverseBoolConverter             x:Key="InverseBoolConverter"/>
  <converters:MsToSecConverter                 x:Key="MsToSecConverter"/>
  <converters:DateToTextConverter              x:Key="DateToTextConverter"/>
  <converters:MessageCountConverter            x:Key="MessageCountConverter"/>
  <converters:ZeroToVisibilityConverter        x:Key="ZeroToVisibilityConverter"/>
  <converters:FloatToLabelConverter            x:Key="FloatToLabelConverter"/>

  <!-- ГўвЂќв‚¬ГўвЂќв‚¬ Brand colors ГўвЂќв‚¬ГўвЂќв‚¬ -->
  <Color x:Key="BrandPurple">#8A63FF</Color>
  <Color x:Key="BrandBlue">#4F9EFF</Color>
  <Color x:Key="BrandTeal">#2DD4BF</Color>
  <Color x:Key="BrandGreen">#4CAF50</Color>
  <Color x:Key="SurfaceDark">#0F0F13</Color>
  <Color x:Key="SurfaceCard">#1A1A24</Color>
  <Color x:Key="SurfaceBorder">#2A2A3A</Color>

  <SolidColorBrush x:Key="BrandPurpleBrush"  Color="{StaticResource BrandPurple}"/>
  <SolidColorBrush x:Key="BrandBlueBrush"    Color="{StaticResource BrandBlue}"/>
  <SolidColorBrush x:Key="BrandTealBrush"    Color="{StaticResource BrandTeal}"/>
  <SolidColorBrush x:Key="BrandGreenBrush"   Color="{StaticResource BrandGreen}"/>
  <SolidColorBrush x:Key="SurfaceDarkBrush"  Color="{StaticResource SurfaceDark}"/>
  <SolidColorBrush x:Key="SurfaceCardBrush"  Color="{StaticResource SurfaceCard}"/>
  <SolidColorBrush x:Key="SurfaceBorderBrush" Color="{StaticResource SurfaceBorder}"/>

  <!-- ГўвЂќв‚¬ГўвЂќв‚¬ Pill / tag style ГўвЂќв‚¬ГўвЂќв‚¬ -->
  <Style x:Key="PillStyle" TargetType="Border">
    <Setter Property="CornerRadius"   Value="20"/>
    <Setter Property="Padding"        Value="10,4"/>
    <Setter Property="Background"     Value="#22FFFFFF"/>
  </Style>

  <!-- ГўвЂќв‚¬ГўвЂќв‚¬ Card style ГўвЂќв‚¬ГўвЂќв‚¬ -->
  <Style x:Key="CardStyle" TargetType="Border">
    <Setter Property="Background"     Value="#1A1A24"/>
    <Setter Property="BorderBrush"    Value="#2A2A3A"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius"   Value="14"/>
    <Setter Property="Padding"        Value="20"/>
  </Style>

  <!-- ГўвЂќв‚¬ГўвЂќв‚¬ Section header text ГўвЂќв‚¬ГўвЂќв‚¬ -->
  <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
    <Setter Property="FontSize"       Value="11"/>
    <Setter Property="FontWeight"     Value="SemiBold"/>
    <Setter Property="CharacterSpacing" Value="120"/>
    <Setter Property="Foreground"     Value="#666688"/>
  </Style>

  <!-- ГўвЂќв‚¬ГўвЂќв‚¬ Code font ГўвЂќв‚¬ГўвЂќв‚¬ -->
  <Style x:Key="CodeTextStyle" TargetType="TextBlock">
    <Setter Property="FontFamily"     Value="Cascadia Code, Consolas, monospace"/>
    <Setter Property="FontSize"       Value="13"/>
  </Style>

</ResourceDictionary>
